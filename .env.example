# ============================================
# NEXT.JS SOCIAL NETWORK - ENV EXAMPLE
# ============================================
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to version control.

# ============================================
# NEXT.JS
# ============================================
NEXT_PUBLIC_API_URL=http://localhost:3000/api/v1

# ============================================
# DATABASE (PostgreSQL)
# ============================================
DATABASE_URL=postgresql://postgres:password@localhost:5432/social_network_local

# ============================================
# JWT AUTHENTICATION
# ============================================
JWT_SECRET=your_jwt_secret_change_this
JWT_EXPIRES_IN=5m
REFRESH_TOKEN_EXPIRES_IN=30d

# ============================================
# IMAGEKIT (Image Upload)
# ============================================
IMAGEKIT_PUBLIC_KEY=your_public_key
IMAGEKIT_PRIVATE_KEY=your_private_key
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your_imagekit_id

# ============================================
# STRIPE (Payments)
# ============================================
STRIPE_SECRET_KEY=sk_test_your_test_stripe_secret_key
STRIPE_PUBLIC_KEY=pk_test_your_test_stripe_public_key
STRIPE_WEBHOOK_SECRET=whsec_your_test_webhook_secret
STRIPE_PRO_PRICE_ID=price_your_stripe_price_id
STRIPE_PRO_PRICE_CENTS=999
STRIPE_PRO_CURRENCY=usd
